# Google Flow（固定项目页，已登录）
FLOW_URL=https://labs.google/fx/zh/tools/flow/project/147a46cc-6217-4b1f-a162-e5bcfcd96b9b
FLOW_CDP_PORT=9335
FLOW_BROWSER_PROFILE=%USERPROFILE%\.hermes\flow-browser

# 视频参数
FLOW_ASPECT_RATIO=16:9
FLOW_SEGMENT_DURATION_SEC=6
FLOW_SEGMENT_COUNT=10
FLOW_GENERATION_TIMEOUT_SEC=300
FLOW_GENERATION_RETRIES=2

# 下载目录（{topic} 会被替换为选题 slug）
FLOW_DOWNLOAD_DIR=%USERPROFILE%\Desktop\douyin-videos\{topic}

# 剪映 UI 自动化
JIANYING_EXE=%LOCALAPPDATA%\JianyingPro\Apps\JianyingPro.exe
JIANYING_STARTUP_TIMEOUT_SEC=30
JIANYING_IMPORT_TIMEOUT_SEC=60
JIANYING_SPLIT_SENTENCE_TIMEOUT_SEC=300
JIANYING_VOICE_NAME=活力科普
JIANYING_VOICE_TAB=收藏
