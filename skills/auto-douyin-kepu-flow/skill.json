{
  "name": "auto-douyin-kepu-flow",
  "display_name": "抖音一分钟科普 · Google Flow",
  "version": "1.1.0",
  "description": "抖音一分钟科普：选题生成、N段6秒Flow prompt（16:9）、Playwright批量提交+监听+720p下载。斜杠：/auto-douyin-kepu-flow",
  "instructions_file": "SKILL.md",
  "entrypoints": {
    "windows": {
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "..\\..\\douyin-kepu-flow\\hermes-launch.ps1",
        "-Script",
        "run_batch.ps1",
        "-PromptsFile",
        "douyin-kepu-flow\\prompts\\example-bank-lending\\prompts.json"
      ],
      "cwd": "."
    }
  },
  "inputs": {
    "prompts_file": {
      "type": "string",
      "required": false,
      "description": "prompts.json 路径，相对仓库根（auto_video）"
    },
    "submit_only": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "true=仅提交 prompt；false=监听百分比后下载"
    }
  },
  "dependencies": ["playwright", "python"],
  "tags": [
    "douyin",
    "kepu",
    "科普",
    "flow",
    "google-flow",
    "veo",
    "video",
    "playwright",
    "一分钟",
    "选题",
    "prompt",
    "auto-douyin"
  ]
}
